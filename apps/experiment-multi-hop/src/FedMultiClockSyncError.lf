target uC {
  platform: {
    name: Zephyr,
    board: nrf52833dk/nrf52833
  },
  net-interface: sicslowpan,
  logging: warn,
  clock-sync: on
}

preamble {=
  #include "reactor-uc/reactor-c.h"
=}

reactor Source {
  preamble {=
    #include <zephyr/kernel.h>
    #include <zephyr/drivers/gpio.h>
    #include <assert.h>
    #define LED0_NODE DT_PATH(leds, led_0)
    static const struct gpio_dt_spec led = GPIO_DT_SPEC_GET(LED0_NODE, gpios);
  =}

  output out: int

  state counter: int = 0

  timer t(0, 250 msec)

  reaction(startup) {=
    assert(device_is_ready(led.port));
    gpio_pin_configure_dt(&led, GPIO_OUTPUT_ACTIVE);
  =}

  reaction(t) -> out {=
    self->counter++;

    lf_set(out, self->counter);
    interval_t ts = lf_time_logical_elapsed();
    interval_t Ts = lf_time_physical_elapsed();

    FederatedEnvironment* envFed = (FederatedEnvironment*)env;
    interval_t t_physclock = envFed->clock.get_time(&envFed->clock);

    printf(
        "[0] Value %d at physical time %lld.%01lld ms and logical time %lld ms\n",
        self->counter,
        t_physclock / 1000000,
        (t_physclock % 1000000) / 100000,
        ts / 1000000
    );

    gpio_pin_toggle_dt(&led);
  =}
}

reactor Sink(id: int = 1) {
  preamble {=
    #include <zephyr/kernel.h>
    #include <zephyr/drivers/gpio.h>
    #include <assert.h>
    #define LED0_NODE DT_PATH(leds, led_0)
    static const struct gpio_dt_spec led = GPIO_DT_SPEC_GET(LED0_NODE, gpios);
  =}

  input in: int

  reaction(startup) {=
    assert(device_is_ready(led.port));
    gpio_pin_configure_dt(&led, GPIO_OUTPUT_ACTIVE);
  =}

  reaction(in) {=
    interval_t ts = lf_time_logical_elapsed();
    interval_t Ts = lf_time_physical_elapsed();

    FederatedEnvironment* envFed = (FederatedEnvironment*)env;
    interval_t t_physclock = envFed->clock.get_time(&envFed->clock);

    printf(
        "[%d] Value %d at physical time %lld.%01lld ms and logical time %lld ms\n",
        self->id,
        in->value,
        t_physclock / 1000000,
        (t_physclock % 1000000) / 100000,
        ts / 1000000
    );

    gpio_pin_toggle_dt(&led);
  =}
}

federated reactor {
  @interface_tcp(address="fd01::1")
  srcFed = new Source()
  @interface_tcp(address="fd01::3")
  snkFed = new Sink(id=1)

  @buffer(20)
  srcFed.out -> snkFed.in after 50ms
}
